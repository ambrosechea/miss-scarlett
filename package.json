{
  "name": "miss-scarlett",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.tsx",
    "preview": "vite preview",
    "worker:dev": "wrangler dev --config wrangler.toml",
    "worker:deploy": "npm run build && wrangler deploy",
    "db:create": "wrangler d1 create miss-scarlett",
    "db:migrate:local": "wrangler d1 migrations apply miss-scarlett --local",
    "db:migrate:remote": "wrangler d1 migrations apply miss-scarlett --remote"
  },
  "dependencies": {
    "@fontsource-variable/oswald": "^5.1.0",
    "@fontsource/lato": "^5.1.1",
    "@tailwindcss/vite": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "swiper": "^11.1.9",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "csv-parse": "^6.2.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "wrangler": "^4.95.0"
  }
}
